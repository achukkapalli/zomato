# Hugging Face dataset
HF_DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation

# Optional: processed Parquet cache (created on first load, speeds up restarts)
# DATA_SNAPSHOT_PATH=data/cache/restaurants.parquet

# LLM — Groq (Phase 3+)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Or use LLM_API_KEY as an alias for GROQ_API_KEY
# LLM_API_KEY=

# Optional Groq tuning
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=2048
# LLM_REQUEST_TIMEOUT=60

# Recommendation limits
MAX_CANDIDATES=30
TOP_K=5
DEFAULT_MIN_RATING=3.0
MAX_ADDITIONAL_PREFERENCES_LENGTH=500

# Budget bands (JSON): cost for two in INR
BUDGET_BANDS={"low":{"max":500},"medium":{"min":500,"max":1500},"high":{"min":1500}}

# App
APP_ENV=development
LOG_LEVEL=INFO
